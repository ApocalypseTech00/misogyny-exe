<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 1000" width="1000" height="1000">
  <rect width="1000" height="1000" fill="#000"/>
  <text x="500" y="420" font-family="serif" font-style="italic" font-size="42" fill="#fff" text-anchor="middle" opacity="0.6">
    "Women are nothing but machines
  </text>
  <text x="500" y="475" font-family="serif" font-style="italic" font-size="42" fill="#fff" text-anchor="middle" opacity="0.6">
    for producing children."
  </text>
  <text x="500" y="560" font-family="monospace" font-size="24" fill="#fff" text-anchor="middle" opacity="0.4">
    — Napoleon Bonaparte
  </text>
  <text x="500" y="920" font-family="monospace" font-size="16" fill="#fff" text-anchor="middle" opacity="0.2">
    MISOGYNY.EXE — TEST
  </text>
</svg>
