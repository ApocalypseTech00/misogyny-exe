# MISOGYNY.EXE V6 — canonical .env template
#
# Copy to .env, populate, `chmod 600 .env`. Never commit a real .env.
# Structure mirrors docs/v6-spec.md §13.

# --- Bot wallet (Pi) ---
# The ONLY wallet that lives on the Pi. Has writer role on all three V6
# contracts. Holds ~2 weeks of gas. Generate via `cast wallet new` on the Pi.
PRIVATE_KEY=
BOT_ADDRESS=

# --- Deployer + treasury wallet addresses (for verification, NOT keys) ---
# These are plain software EOAs on the operator's laptop in MetaMask.
# DEPLOYER_A owns CollectionAdmin. DEPLOYER_B owns QuoteRegistry.
# TREASURY is the hardcoded destination for SplitGuard.emergencyWithdraw.
# Paper seed for each, stored physically separate from the laptop.
DEPLOYER_A_ADDRESS=
DEPLOYER_B_ADDRESS=
TREASURY_ADDRESS=

# --- RPC endpoints ---
ETHEREUM_MAINNET_RPC_URL=
ETHEREUM_SEPOLIA_RPC_URL=
ETHERSCAN_API_KEY=

# --- Queue integrity (MANDATORY, >=32 chars) ---
# Generate: openssl rand -hex 32
# NO FALLBACK. scraper.ts throws on missing/short. Covers {id, quote, roast}.
QUEUE_HMAC_SECRET=

# --- V6 contracts (populated by scripts/deploy-v6.ts) ---
RARE_CONTRACT_ADDRESS=
RARE_CHAIN=sepolia
RARE_STARTING_PRICE=0.01
RARE_AUCTION_DURATION=86400
COLLECTION_ADMIN_ADDRESS=
QUOTE_REGISTRY_ADDRESS=
PRIMARY_SPLITTER_ADDRESS=
SECONDARY_SPLITTER_ADDRESS=
SPLIT_GUARD_ADDRESS=

# --- Revenue destinations (MUST be non-placeholder before first mint) ---
# deploy-v6.ts refuses to run if any of these look like a placeholder 0x...0001 etc.
CHARITY_ADDRESS=
ARTIST_ADDRESS=
PROJECT_ADDRESS=

# --- IPFS + AI ---
PINATA_JWT=
ANTHROPIC_API_KEY=
# Hard daily cap in USD. Agent aborts cycle if exceeded. Default 10.
ANTHROPIC_DAILY_USD_CAP=10

# --- Scraper (optional — Reddit OAuth gives 60 req/min vs 10) ---
# The Pi's residential IP is the scraping strategy; OAuth is for rate-limit boost only.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# --- Telegram approval flow (mandatory for V6) ---
# Create a burner bot via @BotFather on a burner Telegram account.
# Chat ID: start the bot, send /start, then call
#   curl "https://api.telegram.org/bot<TOKEN>/getUpdates"
# and copy `message.chat.id` from the response.
TELEGRAM_BOT_TOKEN=
TELEGRAM_OPERATOR_CHAT_ID=

# --- Socials ---
# Bluesky is the only social wired for V6. Burner handle + app password.
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
MARKETPLACE_BASE_URL=https://apocalypsetech.xyz/marketplace.html

# --- Healthcheck (Healthchecks.io free tier) ---
# Agent pings this URL on every successful cycle. Alerts after 26h silence.
HEALTHCHECK_URL=

# --- Agent tuning ---
# Spec §8.1. Defaults for Phase 4 stabilization (first 30 days). Crank to
# MAX_PER_CYCLE=3, DAILY_LIMIT=12 after initial soak.
AGENT_INTERVAL=720
AGENT_MIN_SCORE=80
AGENT_MAX_PER_CYCLE=1
AGENT_DAILY_LIMIT=2
AGENT_MAX_PENDING=10
