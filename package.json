{
  "name": "misogyny-exe",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network base-sepolia",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network base-mainnet",
    "deploy:v3:testnet": "hardhat run scripts/deploy-v3.ts --network base-sepolia",
    "deploy:v3:mainnet": "hardhat run scripts/deploy-v3.ts --network base-mainnet",
    "mint": "hardhat run scripts/auto-mint.ts --network base-sepolia",
    "mint:mainnet": "hardhat run scripts/auto-mint.ts --network base-mainnet",
    "mint:watch": "MINT_WATCH=true hardhat run scripts/auto-mint.ts --network base-mainnet",
    "index": "hardhat run scripts/indexer.ts --network base-sepolia",
    "index:mainnet": "hardhat run scripts/indexer.ts --network base-mainnet",
    "index:watch": "INDEX_WATCH=true hardhat run scripts/indexer.ts --network base-mainnet",
    "artwork": "ts-node scripts/generate-artwork.ts",
    "collection:status": "MANAGE_CMD=status hardhat run scripts/manage-collection.ts --network base-mainnet",
    "collection:auctions": "MANAGE_CMD=create-auctions hardhat run scripts/manage-collection.ts --network base-mainnet",
    "test:splits": "hardhat run scripts/test-splits.ts --network base-sepolia",
    "generate:qr": "ts-node scripts/generate-qr.ts",
    "deploy:ipfs": "ts-node scripts/deploy-ipfs.ts",
    "upload": "ts-node scripts/upload-to-ipfs.ts",
    "scrape": "ts-node scripts/scraper.ts",
    "scrape:stats": "ts-node scripts/scraper.ts --stats",
    "scrape:approve": "ts-node scripts/scraper.ts --approve",
    "agent": "ts-node scripts/autonomous-agent.ts",
    "agent:testnet": "AGENT_NETWORK=base-sepolia ts-node scripts/autonomous-agent.ts",
    "agent:dry": "AGENT_DRY_RUN=true ts-node scripts/autonomous-agent.ts",
    "agent:once": "AGENT_ONCE=true ts-node scripts/autonomous-agent.ts",
    "guard:test": "ts-node scripts/quote-guard.ts",
    "guard:test:full": "ts-node scripts/quote-guard.ts --full",
    "social:test": "ts-node scripts/post-to-socials.ts",
    "social:send": "ts-node scripts/post-to-socials.ts --send",
    "social:dry": "SOCIAL_DRY_RUN=true ts-node scripts/post-to-socials.ts --send",
    "rare:deploy": "ts-node scripts/rare-mint.ts -- --deploy",
    "rare:mint": "ts-node scripts/rare-mint.ts",
    "rare:status": "ts-node scripts/rare-mint.ts -- --status",
    "rare:agent": "ts-node scripts/rare-agent.ts",
    "rare:agent:dry": "AGENT_DRY_RUN=true ts-node scripts/rare-agent.ts",
    "rare:agent:once": "AGENT_ONCE=true ts-node scripts/rare-agent.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "hardhat": "^2.28.6",
    "pinata": "^2.5.5",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "canvas": "^3.2.1",
    "dotenv": "^17.3.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "viem": "^2.47.4"
  }
}
